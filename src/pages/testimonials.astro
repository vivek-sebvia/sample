---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";

let testimonials = [];
try {
  const res = await fetch(
    `${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=20`,
  );
  testimonials = (await res.json()).docs || [];
} catch {}

// Add premium sample reviews for immediate visual feedback
const sampleReviews = [
  {
    name: "Cameron Williamson",
    text: "Working with this team was one of the best decisions we made for our home. They transformed our dull, uneven lawn into a beautiful, fresh green landscape that we now absolutely love.",
    location: "Homeowner in " + client.city,
    stars: 5,
  },
  {
    name: "Jane Cooper",
    text: "The attention to detail was incredible. The turfing work was extremely clean, the finishing was perfect, and everything was completed right on schedule. Highly recommend!",
    location: "Local Resident",
    stars: 5,
  },
  {
    name: "Jenny Wilson",
    text: "Professional, reliable, and extremely talented. They took our vague ideas and turned them into a stunning garden that has become our favorite part of the house.",
    location: "Estate Manager",
    stars: 5,
  },
  {
    name: "Mike Smith",
    text: "The installation was quick and hassle-free. They cleaned up the entire area perfectly when they were done. Very satisfied!",
    location: "Estate Manager",
    stars: 4,
  },
];

// Merge samples if CMS is empty or has few reviews
if (testimonials.length < 3) {
  testimonials = [...testimonials, ...sampleReviews];
}

const primary = client.primaryColor || "#2d5a3d";
---

<Layout
  title="Reviews"
  description={`Reviews from satisfied customers of ${client.name}.`}
>
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Customer Reviews</h1>
      <p class="hero-description">
        See what our customers say about our work and the experience of working
        with {client.name}.
      </p>
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="separator">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><polyline points="9 18 15 12 9 6"></polyline></svg
          >
        </span>
        <span class="current">Reviews</span>
      </div>
    </div>
  </section>

  <section class="tm-section">
    <div class="tm-container">
      {
        testimonials.length > 0 ? (
          <div class="tm-carousel-root">
            <div class="tm-viewport">
              <div class="tm-track" id="tmTrack">
                {testimonials.map((t: any) => (
                  <div class="tm-card">
                    <div class="tm-stars">
                      {[...Array(5)].map(() => (
                        <svg
                          width="18"
                          height="18"
                          viewBox="0 0 24 24"
                          fill="#a8cf45"
                        >
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                        </svg>
                      ))}
                    </div>
                    <p class="tm-text">"{t.text || t.content}"</p>
                    <div class="tm-footer">
                      <div class="tm-avatar" style={`background: ${primary}`}>
                        {t.image?.url ? (
                          <img src={t.image.url} alt={t.name || t.author} />
                        ) : (
                          <span>
                            {(t.name || t.author || "A")
                              .charAt(0)
                              .toUpperCase()}
                          </span>
                        )}
                      </div>
                      <div class="tm-info">
                        <h4 class="tm-author-name">{t.name || t.author}</h4>
                        <p class="tm-author-role">
                          {t.location || "Verified Client"}
                        </p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <button class="tm-nav-btn prev" id="tmPrev" aria-label="Previous">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="15 18 9 12 15 6" />
              </svg>
            </button>
            <button class="tm-nav-btn next" id="tmNext" aria-label="Next">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </button>
          </div>
        ) : (
          <div class="tm-empty">
            <p>No reviews yet.</p>
          </div>
        )
      }
    </div>
  </section>

  <style>
    .tm-section {
      padding: 120px 0;
      background: #fff;
      overflow: hidden;
    }
    .tm-container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 20px;
    }
    .tm-carousel-root {
      position: relative;
      padding: 0 50px;
    }
    .tm-viewport {
      overflow: hidden; /* Changed to hidden to prevent extra cards from showing */
      padding: 40px 0; /* Increased padding to accommodate hover lift */
      margin: -20px 0; /* Offset padding to keep layout tight */
    }
    .tm-track {
      display: flex !important;
      gap: 2rem;
      transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    }
    .tm-card {
      flex: 0 0 calc((100% - 4rem) / 3);
      background: #f7f9f0;
      padding: 3rem 2.5rem;
      border-radius: 24px;
      display: flex;
      flex-direction: column;
      transition: all 0.4s ease;
      border: 1px solid transparent;
      box-sizing: border-box;
      height: 100%;
    }
    .tm-card:hover {
      transform: translateY(-10px);
      background: #fff;
      border-color: #e5e9d6;
      box-shadow: 0 20px 40px rgba(10, 30, 15, 0.06);
    }
    .tm-stars {
      display: flex;
      gap: 4px;
      margin-bottom: 1.5rem;
    }
    .tm-text {
      font-size: 1.05rem;
      line-height: 1.7;
      color: #374151;
      font-style: italic;
      margin-bottom: 2rem;
      flex-grow: 1;
    }
    .tm-footer {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(0, 0, 0, 0.05);
    }
    .tm-avatar {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
      overflow: hidden;
      flex-shrink: 0;
    }
    .tm-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .tm-author-name {
      font-size: 1.05rem;
      font-weight: 700;
      color: #0a1e0f;
      margin-bottom: 2px;
    }
    .tm-author-role {
      font-size: 0.85rem;
      color: #6b7280;
    }

    /* Navigation Buttons */
    .tm-nav-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 60px;
      height: 60px;
      background: #fff;
      border: 1px solid #e5e9d6;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0a1e0f;
      cursor: pointer;
      z-index: 100;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }
    .tm-nav-btn:hover {
      background: #a8cf45;
      color: #fff;
      border-color: #a8cf45;
      transform: translateY(-50%) scale(1.1);
      box-shadow: 0 8px 25px rgba(168, 207, 69, 0.4);
    }
    .tm-nav-btn.prev {
      left: -10px;
    }
    .tm-nav-btn.next {
      right: -10px;
    }

    @media (max-width: 1100px) {
      .tm-card {
        flex: 0 0 calc((100% - 2rem) / 2);
      }
    }
    @media (max-width: 768px) {
      .tm-card {
        flex: 0 0 100%;
      }
      .tm-nav-btn {
        display: none;
      }
      .tm-section {
        padding: 60px 0;
      }
      .tm-carousel-root {
        padding: 0;
      }
      .tm-viewport {
        overflow-x: auto;
        scroll-snap-type: x mandatory;
      }
      .tm-card {
        scroll-snap-align: center;
      }
    }
  </style>

  <script>
    function initTmCarousel() {
      const track = document.getElementById("tmTrack") as HTMLElement;
      const prevBtn = document.getElementById("tmPrev") as HTMLElement;
      const nextBtn = document.getElementById("tmNext") as HTMLElement;

      if (!track || !prevBtn || !nextBtn) return;

      // Clean up previous clones if re-initializing
      const originalCards = Array.from(track.querySelectorAll('.tm-card:not(.tm-clone)')) as HTMLElement[];
      if (originalCards.length < 2) return; // Need at least 2 cards for meaningful loop

      track.innerHTML = '';
      originalCards.forEach(card => track.appendChild(card));

      const visibleCards = window.innerWidth > 1100 ? 3 : window.innerWidth > 768 ? 2 : 1;
      
      // Clone cards for infinite loop
      const firstClones = originalCards.slice(0, visibleCards).map(card => {
        const clone = card.cloneNode(true) as HTMLElement;
        clone.classList.add('tm-clone');
        return clone;
      });
      
      const lastClones = originalCards.slice(-visibleCards).map(card => {
        const clone = card.cloneNode(true) as HTMLElement;
        clone.classList.add('tm-clone');
        return clone;
      });

      lastClones.reverse().forEach(clone => track.insertBefore(clone, track.firstChild));
      firstClones.forEach(clone => track.appendChild(clone));

      const allCards = Array.from(track.children) as HTMLElement[];
      let currentIndex = visibleCards;
      let isTransitioning = false;

      function updateCarousel(smooth = true) {
        const cardWidth = originalCards[0].offsetWidth;
        const style = window.getComputedStyle(track);
        const gap = parseInt(style.gap) || 0;
        
        track.style.transition = smooth ? "transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)" : "none";
        const moveDistance = (cardWidth + gap) * currentIndex;
        track.style.transform = `translateX(-${moveDistance}px)`;
      }

      function handleNext() {
        if (isTransitioning) return;
        isTransitioning = true;
        currentIndex++;
        updateCarousel();
      }

      function handlePrev() {
        if (isTransitioning) return;
        isTransitioning = true;
        currentIndex--;
        updateCarousel();
      }

      track.addEventListener('transitionend', () => {
        isTransitioning = false;
        
        if (currentIndex >= allCards.length - visibleCards) {
          currentIndex = visibleCards;
          updateCarousel(false);
        } else if (currentIndex < visibleCards) {
          currentIndex = allCards.length - (visibleCards * 2);
          updateCarousel(false);
        }
      });

      nextBtn.addEventListener("click", handleNext);
      prevBtn.addEventListener("click", handlePrev);

      window.addEventListener("resize", () => {
        // Simple re-init on resize to handle changing visibleCards count
        initTmCarousel();
      });

      // Initial position
      updateCarousel(false);
    }

    // Run on page load and after swaps
    initTmCarousel();
    document.addEventListener("astro:after-swap", initTmCarousel);
  </script>

  <section class="cta-section">
    <div class="cta-overlay"></div>
    <div class="container cta-container">
      <div class="cta-content">
        <h2 class="cta-title">Join Our Happy Customers</h2>
        <p class="cta-desc">
          Ready to experience the {client.name} difference? Contact us today to start
          your project.
        </p>
        <div class="cta-actions">
          <a href="/contact" class="cta-primary-btn">Get Free Quote</a>
          <a href={`tel:${client.phone}`} class="cta-phone-link">
            <div class="phone-icon-circle">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                ><path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path></svg
              >
            </div>
            <span class="phone-text">{client.phone}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative Elements -->
    <div class="cta-decoration-left">
      <img src="/images/services/landscape-design.png" alt="" />
    </div>
    <div class="cta-decoration-right">
      <img src="/images/services/garden-installation.png" alt="" />
    </div>
    <div class="cta-grass-border"></div>
  </section>

  <style>
    .page-hero {
      position: relative;
      background: url("/images/hero-bg.png") center/cover no-repeat;
      padding: 180px 0 100px;
      text-align: center;
      color: white;
      min-height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10, 30, 15, 0.7),
        rgba(10, 30, 15, 0.5)
      );
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .hero-title {
      font-size: clamp(3rem, 10vw, 5rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      text-transform: capitalize;
    }
    .hero-description {
      color: rgba(255, 255, 255, 0.9);
      max-width: 700px;
      margin: 0 auto 20px auto;
      font-size: 1.15rem;
      line-height: 1.6;
      font-weight: 300;
    }
    .breadcrumbs {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }
    .breadcrumbs a {
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .breadcrumbs a:hover {
      color: #c7e57c;
    }
    .separator {
      color: #c7e57c;
      display: flex;
      align-items: center;
    }
    .current {
      color: white;
    }

    @media (max-width: 768px) {
      .page-hero {
        padding: 140px 0 60px;
        min-height: 300px;
      }
      .hero-title {
        font-size: 2.5rem;
      }
    }

    .cta-section {
      position: relative;
      padding: 140px 0 100px;
      background:
        linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
        url("/images/hero-bg.png") center/cover no-repeat;
      color: white;
      text-align: center;
      overflow: hidden;
    }
    .cta-container {
      position: relative;
      z-index: 5;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .cta-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
    }
    .cta-desc {
      font-size: 1.2rem;
      opacity: 0.95;
      line-height: 1.7;
      margin-bottom: 3rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }
    .cta-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }
    .cta-primary-btn {
      background: #a8cf45;
      color: white;
      padding: 1.1rem 2.8rem;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 800;
      font-size: 1.1rem;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 15px rgba(168, 207, 69, 0.3);
    }
    .cta-primary-btn:hover {
      background: #96bb3d;
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(168, 207, 69, 0.4);
    }
    .cta-phone-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: white;
      text-decoration: none;
      font-weight: 700;
      font-size: 1.5rem;
      transition: opacity 0.3s ease;
    }
    .cta-phone-link:hover {
      opacity: 0.8;
    }
    .phone-icon-circle {
      width: 48px;
      height: 48px;
      background: rgba(255, 255, 255, 0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .cta-decoration-left {
      position: absolute;
      bottom: -20px;
      left: -2%;
      width: 420px;
      z-index: 2;
      filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
    }
    .cta-decoration-right {
      position: absolute;
      bottom: -40px;
      right: -2%;
      width: 380px;
      z-index: 2;
      filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.3));
    }
    .cta-decoration-left img,
    .cta-decoration-right img {
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    .cta-grass-border {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 80px;
      background: #0a1e0f;
      z-index: 10;
      clip-path: polygon(
        0% 100%,
        100% 100%,
        100% 30%,
        98% 45%,
        96% 25%,
        94% 40%,
        92% 20%,
        90% 35%,
        88% 15%,
        86% 30%,
        84% 10%,
        82% 25%,
        80% 5%,
        78% 20%,
        76% 0%,
        74% 15%,
        72% 0%,
        70% 15%,
        68% 5%,
        66% 20%,
        64% 10%,
        62% 25%,
        60% 15%,
        58% 30%,
        56% 15%,
        54% 35%,
        52% 20%,
        50% 40%,
        48% 25%,
        46% 45%,
        44% 30%,
        42% 50%,
        40% 35%,
        38% 55%,
        36% 40%,
        34% 60%,
        32% 45%,
        30% 65%,
        28% 50%,
        26% 70%,
        24% 55%,
        22% 75%,
        20% 60%,
        18% 80%,
        16% 65%,
        14% 85%,
        12% 70%,
        10% 90%,
        8% 75%,
        6% 95%,
        4% 80%,
        2% 100%,
        0% 85%
      );
    }

    @media (max-width: 992px) {
      .cta-decoration-left,
      .cta-decoration-right {
        display: none;
      }
      .cta-section {
        padding: 80px 0;
      }
      .cta-actions {
        flex-direction: column;
        gap: 2rem;
      }
    }
  </style>
</Layout>
