---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Contact Us" description={`Contact ${client.name} for a free estimate. Serving ${client.city}, ${client.state}.`}>

  <!-- Hero Section -->
  <section class="page-hero">
    <div class="overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Contact Us</h1>
      <p class="hero-description">
        Get your free estimate today. We respond within 24 hours to help bring your outdoor vision to life.
      </p>
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="separator">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </span>
        <span class="current">Contact</span>
      </div>
    </div>
  </section>

  <style>
    .page-hero {
      position: relative;
      background: url('/images/hero-bg.png') center/cover no-repeat;
      padding: 180px 0 100px;
      text-align: center;
      color: white;
      min-height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10, 30, 15, 0.7), rgba(10, 30, 15, 0.5));
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .hero-title {
      font-size: clamp(3rem, 10vw, 5rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      text-transform: capitalize;
    }
    .hero-description {
      color: rgba(255, 255, 255, 0.9);
      max-width: 700px;
      margin: 0 auto 20px auto;
      font-size: 1.15rem;
      line-height: 1.6;
      font-weight: 300;
    }
    .breadcrumbs {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }
    .breadcrumbs a {
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .breadcrumbs a:hover {
      color: #c7e57c;
    }
    .separator {
      color: #c7e57c;
      display: flex;
      align-items: center;
    }
    .current {
      color: white;
    }

    @media (max-width: 768px) {
      .page-hero {
        padding: 140px 0 60px;
        min-height: 300px;
      }
      .hero-title {
        font-size: 2.5rem;
      }
    }
  </style>

  <section class="cn-info-section">
    <div class="cn-container">
      <div class="cn-info-grid">
        <div class="cn-info-card reveal-item" style="transition-delay: 100ms;">
          <div class="cn-icon-circle">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a8cf45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div class="cn-card-content">
            <h3>Address Line</h3>
            <p>{client.address}</p>
            <p>{client.city}, {client.state}</p>
          </div>
          <div class="cn-card-glow"></div>
        </div>

        <div class="cn-info-card reveal-item" style="transition-delay: 250ms;">
          <div class="cn-icon-circle">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a8cf45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <div class="cn-card-content">
            <h3>Phone Number</h3>
            <p>{client.phone}</p>
            <p>Office: {client.phone}</p>
          </div>
          <div class="cn-card-glow"></div>
        </div>

        <div class="cn-info-card reveal-item" style="transition-delay: 400ms;">
          <div class="cn-icon-circle">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a8cf45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <div class="cn-card-content">
            <h3>Mail Address</h3>
            <p>{client.email}</p>
            <p>support@example.com</p>
          </div>
          <div class="cn-card-glow"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="cn-main-section reveal-item">
    <div class="cn-container">
      <div class="cn-contact-box">
        <div class="cn-map-side">
          <div class="cn-map-container">
            <iframe 
              src={`https://www.google.com/maps/embed/v1/place?key=YOUR_API_KEY&q=${encodeURIComponent(client.address + ' ' + client.city + ' ' + client.state)}`}
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              class="cn-map-frame"
            ></iframe>
            <!-- Fallback if no API key -->
            {!import.meta.env.GOOGLE_MAPS_API_KEY && (
              <div class="cn-map-placeholder">
                <img src="/images/hero-bg.png" alt="Map Location" />
                <div class="cn-map-overlay">
                  <a href={`https://www.google.com/maps/search/${encodeURIComponent(client.address + ' ' + client.city)}`} target="_blank" class="cn-map-btn">
                    <span>Explore on Google Maps</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                  </a>
                </div>
              </div>
            )}
          </div>
        </div>

        <div class="cn-form-side">
          <div class="cn-tag-wrapper">
            <span class="cn-tag-line"></span>
            <span class="cn-tag">Get IN Touch</span>
          </div>
          <h2 class="cn-form-title">Book An <br/>Appointment</h2>
          
          <form id="contact-form" class="cn-form">
            <div class="cn-input-row">
              <div class="cn-field">
                <input type="text" name="firstName" placeholder="First Name *" required />
                <span class="cn-focus-border"></span>
              </div>
              <div class="cn-field">
                <input type="text" name="lastName" placeholder="Last Name *" required />
                <span class="cn-focus-border"></span>
              </div>
            </div>
            <div class="cn-input-row">
              <div class="cn-field">
                <input type="email" name="email" placeholder="Email Address" required />
                <span class="cn-focus-border"></span>
              </div>
              <div class="cn-field">
                <input type="tel" name="phone" placeholder="Phone Number *" required />
                <span class="cn-focus-border"></span>
              </div>
            </div>
            <div class="cn-field cn-custom-dropdown" id="service-dropdown">
              <div class="cn-dropdown-trigger">
                <span class="cn-trigger-text">Service Needed *</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="cn-dropdown-arrow"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="cn-dropdown-menu">
                {client.services.map((s: string) => (
                  <div class="cn-dropdown-item" data-value={s}>{s}</div>
                ))}
                <div class="cn-dropdown-item" data-value="other">Other</div>
              </div>
              <!-- Visually hidden but validatable input -->
              <input 
                type="text" 
                name="service" 
                required 
                id="service-hidden-input" 
                tabindex="-1"
                style="position: absolute; opacity: 0; width: 0; height: 0; bottom: 0; left: 50%; pointer-events: none;"
              />
              <span class="cn-focus-border"></span>
            </div>
            <div class="cn-field">
              <textarea name="message" placeholder="Describe your project..." rows="5"></textarea>
              <span class="cn-focus-border"></span>
            </div>
            
            <button type="submit" class="cn-submit-btn">
              <span class="btn-text">SEND A MESSAGE</span>
              <span class="btn-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </span>
            </button>
          </form>

          <div id="form-success" class="cn-success-msg">
            <div class="cn-success-icon">
              <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#a8cf45" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <h3>Message Sent Successfully!</h3>
            <p>Our team will reach out to you within the next 24 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Scroll Reveal Animations */
    .reveal-item {
      opacity: 0;
      transform: translateY(40px);
      transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-item.active {
      opacity: 1;
      transform: translateY(0);
    }

    .cn-info-section {
      padding: 100px 0 50px;
      background: #ffffff;
      overflow: hidden;
    }
    .cn-container {
      max-width: 1250px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .cn-info-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
    .cn-info-card {
      position: relative;
      background: #ffffff;
      padding: 4rem 2.5rem;
      border-radius: 32px;
      text-align: center;
      box-shadow: 0 15px 45px rgba(0, 0, 0, 0.04);
      border: 1px solid #f2f4f0;
      overflow: hidden;
      z-index: 1;
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .cn-info-card:hover {
      transform: translateY(-12px);
      box-shadow: 0 25px 60px rgba(10, 30, 15, 0.08);
      border-color: #a8cf45;
    }
    .cn-card-glow {
      position: absolute;
      bottom: -100px;
      right: -100px;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(168, 207, 69, 0.1) 0%, transparent 70%);
      transition: all 0.6s ease;
      z-index: -1;
    }
    .cn-info-card:hover .cn-card-glow {
      transform: scale(2);
      bottom: -50px;
      right: -50px;
    }
    .cn-icon-circle {
      width: 70px;
      height: 70px;
      background: #f7f9f0;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 2rem;
      transition: all 0.5s ease;
    }
    .cn-info-card:hover .cn-icon-circle {
      background: #a8cf45;
      transform: rotate(10deg);
    }
    .cn-info-card:hover .cn-icon-circle svg {
      stroke: white;
    }
    .cn-info-card h3 {
      font-size: 1.4rem;
      font-weight: 800;
      color: #0a1e0f;
      margin-bottom: 1.2rem;
    }
    .cn-info-card p {
      color: #6b7280;
      margin: 0.3rem 0;
      font-size: 1.05rem;
      line-height: 1.6;
    }

    .cn-main-section {
      padding: 50px 0 120px;
    }
    .cn-contact-box {
      background: #fff;
      border-radius: 48px;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.06);
      border: 1px solid #f2f4f0;
    }
    .cn-map-side {
      padding: 2.5rem;
      background: #f8faf5;
    }
    .cn-map-container {
      width: 100%;
      height: 100%;
      border-radius: 32px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .cn-map-frame {
      filter: saturate(0.8) contrast(1.1);
    }
    .cn-map-placeholder {
      position: relative;
      height: 100%;
    }
    .cn-map-placeholder img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(1);
      opacity: 0.4;
    }
    .cn-map-overlay {
      position: absolute;
      inset: 0;
      background: rgba(10, 30, 15, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cn-map-btn {
      background: #0a1e0f;
      color: white;
      padding: 1.2rem 2.2rem;
      border-radius: 100px;
      text-decoration: none;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 15px 30px rgba(10, 30, 15, 0.2);
    }
    .cn-map-btn:hover {
      background: #a8cf45;
      transform: scale(1.05) translateY(-5px);
    }

    .cn-form-side {
      padding: 5rem 4.5rem;
      position: relative;
    }
    .cn-tag-wrapper {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .cn-tag-line {
      width: 30px;
      height: 2px;
      background: #a8cf45;
    }
    .cn-tag {
      color: #a8cf45;
      font-size: 0.9rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .cn-form-title {
      font-size: clamp(2.5rem, 4vw, 3.5rem);
      font-weight: 900;
      color: #0a1e0f;
      margin-bottom: 3.5rem;
      line-height: 1.1;
      letter-spacing: -0.03em;
    }
    .cn-form {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .cn-field {
      position: relative;
    }
    .cn-input-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .cn-form input, .cn-form textarea, .cn-dropdown-trigger {
      width: 100%;
      padding: 1.4rem 1.8rem;
      background: #f7f9f0;
      border: 1px solid transparent;
      border-radius: 16px;
      font-size: 1rem;
      transition: all 0.4s ease;
      color: #0a1e0f;
      box-sizing: border-box;
    }
    .cn-dropdown-trigger {
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
    }
    .cn-dropdown-arrow {
      transition: transform 0.4s ease;
    }
    .cn-custom-dropdown.open .cn-dropdown-arrow {
      transform: rotate(180deg);
    }
    .cn-dropdown-menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-radius: 20px;
      padding: 1rem;
      box-shadow: 0 20px 50px rgba(10, 30, 15, 0.15);
      border: 1px solid rgba(168, 207, 69, 0.2);
      z-index: 100;
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      max-height: 300px;
      overflow-y: auto;
    }
    .cn-custom-dropdown.open .cn-dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .cn-dropdown-item {
      padding: 1rem 1.5rem;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
      color: #0a1e0f;
    }
    .cn-dropdown-item:hover {
      background: #f7f9f0;
      color: #a8cf45;
      padding-left: 2rem;
    }
    .cn-dropdown-item.selected {
      background: #a8cf45;
      color: white;
    }
    .cn-form input:focus, .cn-form textarea:focus, .cn-custom-dropdown.open .cn-dropdown-trigger {
      outline: none;
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .cn-custom-dropdown.open .cn-dropdown-trigger {
      border-color: #a8cf45;
    }
    .cn-focus-border {
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: #a8cf45;
      transition: all 0.4s ease;
      transform: translateX(-50%);
    }
    .cn-form input:focus ~ .cn-focus-border, 
    .cn-form textarea:focus ~ .cn-focus-border {
      width: 60%;
    }

    .cn-submit-btn {
      background: #0a1e0f;
      color: white;
      padding: 1.4rem;
      border-radius: 16px;
      border: none;
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      margin-top: 1.5rem;
    }
    .cn-submit-btn:hover {
      background: #a8cf45;
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(168, 207, 69, 0.25);
    }
    .btn-icon {
      transition: all 0.4s ease;
    }
    .cn-submit-btn:hover .btn-icon {
      transform: translate(5px, -5px) scale(1.1);
    }

    .cn-success-msg {
      display: none;
      text-align: center;
      padding: 2rem 0;
    }
    .cn-success-icon {
      animation: bounceIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .cn-success-msg h3 {
      font-size: 2rem;
      font-weight: 900;
      color: #0a1e0f;
      margin: 1.5rem 0 1rem;
    }
    .cn-success-msg p {
      color: #6b7280;
      font-size: 1.1rem;
      max-width: 400px;
      margin: 0 auto;
    }

    @keyframes bounceIn {
      0% { transform: scale(0); opacity: 0; }
      60% { transform: scale(1.1); }
      100% { transform: scale(1); opacity: 1; }
    }

    @media (max-width: 1100px) {
      .cn-info-grid { grid-template-columns: repeat(2, 1fr); }
      .cn-contact-box { grid-template-columns: 1fr; }
      .cn-form-side { padding: 4rem 2rem; }
    }
    @media (max-width: 768px) {
      .cn-info-grid { grid-template-columns: 1fr; }
      .cn-input-row { grid-template-columns: 1fr; gap: 1.5rem; }
      .cn-form-title { font-size: 2.2rem; }
      .cn-info-section { padding: 80px 0 30px; }
    }
  </style>

  <script>
    // Intersection Observer for Scroll Reveals
    const observerOptions = {
      threshold: 0.15
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        } else {
          // Optional: remove class to animate again on scroll up
          // entry.target.classList.remove('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-item').forEach(item => {
      observer.observe(item);
    });

    // Custom Dropdown Logic
    const dropdown = document.getElementById('service-dropdown');
    const trigger = dropdown?.querySelector('.cn-dropdown-trigger');
    const menu = dropdown?.querySelector('.cn-dropdown-menu');
    const items = dropdown?.querySelectorAll('.cn-dropdown-item');
    const hiddenInput = document.getElementById('service-hidden-input') as HTMLInputElement;
    const triggerText = dropdown?.querySelector('.cn-trigger-text');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle('open');
    });

    items?.forEach(item => {
      item.addEventListener('click', (e) => {
        const val = (item as HTMLElement).dataset.value || '';
        const text = (item as HTMLElement).textContent || '';
        
        if (hiddenInput) hiddenInput.value = val;
        if (triggerText) triggerText.textContent = text;
        
        items.forEach(i => i.classList.remove('selected'));
        item.classList.add('selected');
        
        dropdown?.classList.remove('open');
      });
    });

    // Close on click outside
    document.addEventListener('click', () => {
      dropdown?.classList.remove('open');
    });

    // Form Submission Logic
    document.getElementById('contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = document.getElementById('contact-form') as HTMLElement;
      const success = document.getElementById('form-success') as HTMLElement;
      
      form.style.opacity = '0';
      form.style.transform = 'translateY(-20px)';
      
      setTimeout(() => {
        form.style.display = 'none';
        success.style.display = 'block';
      }, 400);
    });
  </script>
t>