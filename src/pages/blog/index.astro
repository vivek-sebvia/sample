---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../client.config.js'

let posts = []
try {
  const res = await fetch(`${client.cmsUrl}/api/blog?where[tenant.slug][equals]=${client.tenantSlug}&limit=20&sort=-createdAt`)
  posts = (await res.json()).docs || []
} catch {}

const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Blog" description={`Tips and news from ${client.name}.`}>

  <!-- Hero Section -->
  <section class="page-hero">
    <div class="overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">Insights & Inspiration</h1>
      <p class="hero-description">
        Expert landscaping advice, seasonal care tips, and the latest design trends from the {client.name} team.
      </p>
      <div class="breadcrumbs">
        <a href="/">Home</a>
        <span class="separator">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </span>
        <span class="current">Blog</span>
      </div>
    </div>
  </section>

  <style>
    .page-hero {
      position: relative;
      background: url('/images/hero-bg.png') center/cover no-repeat;
      padding: 180px 0 100px;
      text-align: center;
      color: white;
      min-height: 450px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0;
    }
    .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10, 30, 15, 0.8), rgba(10, 30, 15, 0.6));
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
    }
    .hero-title {
      font-size: clamp(3rem, 10vw, 5.5rem);
      font-weight: 900;
      margin-bottom: 1.5rem;
      letter-spacing: -0.04em;
      text-transform: capitalize;
    }
    .hero-description {
      color: rgba(255, 255, 255, 0.9);
      max-width: 800px;
      margin: 0 auto 30px auto;
      font-size: 1.2rem;
      line-height: 1.6;
      font-weight: 300;
    }
    .breadcrumbs {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      font-size: 1.1rem;
      font-weight: 600;
    }
    .breadcrumbs a {
      color: rgba(255, 255, 255, 0.8);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .breadcrumbs a:hover {
      color: #c7e57c;
    }
    .separator {
      color: #c7e57c;
      display: flex;
      align-items: center;
    }
    .current {
      color: white;
    }

    /* Scroll Reveal Animations */
    .reveal-item {
      opacity: 0;
      transform: translateY(30px);
      transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-item.active {
      opacity: 1;
      transform: translateY(0);
    }

    .bl-section {
      padding: 120px 0;
      background: #ffffff;
    }
    .bl-container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .bl-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
    .bl-card {
      background: #ffffff;
      border-radius: 32px;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
      border: 1px solid #f2f4f0;
      display: flex;
      flex-direction: column;
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      text-decoration: none;
    }
    .bl-card:hover {
      transform: translateY(-12px);
      box-shadow: 0 25px 60px rgba(10, 30, 15, 0.08);
      border-color: #a8cf45;
    }
    .bl-image-wrapper {
      position: relative;
      height: 260px;
      overflow: hidden;
    }
    .bl-image-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .bl-card:hover .bl-image-wrapper img {
      transform: scale(1.1);
    }
    .bl-date-badge {
      position: absolute;
      top: 20px;
      left: 20px;
      background: #a8cf45;
      color: #0a1e0f;
      padding: 0.8rem 1rem;
      border-radius: 12px;
      font-weight: 900;
      font-size: 1.1rem;
      box-shadow: 0 5px 15px rgba(168, 207, 69, 0.3);
      z-index: 2;
    }
    .bl-content {
      padding: 2.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .bl-title {
      font-size: 1.4rem;
      font-weight: 800;
      color: #0a1e0f;
      margin-bottom: 1.2rem;
      line-height: 1.4;
      transition: color 0.3s ease;
    }
    .bl-card:hover .bl-title {
      color: #a8cf45;
    }
    .bl-excerpt {
      color: #6b7280;
      font-size: 1.05rem;
      line-height: 1.7;
      margin-bottom: 2rem;
      flex: 1;
    }
    .bl-read-more {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #0a1e0f;
      font-weight: 800;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
    }
    .bl-read-more svg {
      transition: transform 0.3s ease;
    }
    .bl-card:hover .bl-read-more {
      color: #a8cf45;
    }
    .bl-card:hover .bl-read-more svg {
      transform: translate(3px, -3px);
    }

    @media (max-width: 1100px) {
      .bl-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    }
    @media (max-width: 768px) {
      .bl-grid { grid-template-columns: 1fr; }
      .bl-section { padding: 80px 0; }
      .bl-content { padding: 2rem; }
      .hero-title { font-size: 2.5rem; }
    }
  </style>

  <section class="bl-section">
    <div class="bl-container">
      <div class="bl-grid">
        <!-- Static Demo Posts (As Fallback or Featured) -->
        {
          [
            {
              title: "Eco-Friendly Landscaping Ideas You Can Start Today",
              excerpt: "Discover how to create a sustainable and beautiful garden using native plants and water-wise designs.",
              image: "/images/blog/blog-1.png",
              date: "15",
              slug: "eco-friendly-landscaping"
            },
            {
              title: "Top 7 Turf Maintenance Tips for a Healthy Lawn",
              excerpt: "Keep your grass lush and green all year round with our expert maintenance guide for residential lawns.",
              image: "/images/blog/blog-2.png",
              date: "15",
              slug: "turf-maintenance-tips"
            },
            {
              title: "The Best Plants for Shady Areas in Your Backyard",
              excerpt: "Turn those dark corners into vibrant garden spots with these top shade-loving plant recommendations.",
              image: "/images/blog/blog-3.png",
              date: "15",
              slug: "best-plants-shady-areas"
            },
            {
              title: "Creative Backyard Landscaping Ideas for Small Spaces",
              excerpt: "Maximize your outdoor living area with these smart design hacks for small backyards and patios.",
              image: "/images/blog/blog-4.png",
              date: "14",
              slug: "small-backyard-ideas"
            },
            {
              title: "How To Care For Plants Inside A Home Greenhouse",
              excerpt: "Learn the essentials of temperature control and humidity for a thriving indoor plant greenhouse.",
              image: "/images/blog/blog-5.png",
              date: "14",
              slug: "home-greenhouse-care"
            },
            {
              title: "Essential Tips To Keep Your Garden Flowers Blooming",
              excerpt: "Expert advice on seasonal pruning and fertilization to ensure continuous floral displays in your garden.",
              image: "/images/blog/blog-6.png",
              date: "14",
              slug: "garden-flowers-blooming"
            }
          ].map((post, idx) => (
            <a href={`/blog/${post.slug}`} class="bl-card reveal-item" style={`transition-delay: ${idx * 150}ms`}>
              <div class="bl-image-wrapper">
                <span class="bl-date-badge">{post.date}</span>
                <img src={post.image} alt={post.title} />
              </div>
              <div class="bl-content">
                <h2 class="bl-title">{post.title}</h2>
                <p class="bl-excerpt">{post.excerpt}</p>
                <div class="bl-read-more">
                  <span>Read More</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                </div>
              </div>
            </a>
          ))
        }

        <!-- CMS Posts (If any) -->
        {posts.map((post: any, idx: number) => (
          <a href={`/blog/${post.slug}`} class="bl-card reveal-item" style={`transition-delay: ${(idx + 6) * 150}ms`}>
            <div class="bl-image-wrapper">
              <span class="bl-date-badge">{post.createdAt ? new Date(post.createdAt).getDate() : '20'}</span>
              <img src={post.image?.url || '/images/hero-bg.png'} alt={post.title} />
            </div>
            <div class="bl-content">
              <h2 class="bl-title">{post.title}</h2>
              <p class="bl-excerpt">{post.excerpt || 'Read our latest insights and tips for your home landscaping project.'}</p>
              <div class="bl-read-more">
                <span>Read More</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    // Intersection Observer for Scroll Reveals
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        } else {
          entry.target.classList.remove('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-item').forEach(item => {
      observer.observe(item);
    });
  </script>

</Layout>